{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch)",
      "Bash(git branch -a)",
      "Bash(git branch -v)",
      "Bash(git branch -av)",
      "Bash(git branch --list*)",
      "Bash(git remote -v)",
      "Bash(git remote show*)"
    ]
  }
}
